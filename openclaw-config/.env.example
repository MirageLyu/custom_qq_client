# ============================================
# OpenClaw + QQ Bot 环境变量配置
# 复制为 .env 并填入实际值：cp .env.example .env
# ============================================

# ---------- LLM API 配置（必填一个）----------
# 阿里云百炼 DashScope（推荐，国内最稳定）
# 获取方式：https://bailian.console.aliyun.com/ → API-KEY 管理
DASHSCOPE_API_KEY=sk-你的百炼API密钥

# ---------- QQ Bot 配置（必填）----------
# 在 https://q.qq.com/ 创建机器人后获取
# AppID: 机器人管理页面 → 开发 → 开发设置 → AppID
# AppSecret: 同页面 → AppSecret
QQBOT_APPID=你的AppID
QQBOT_SECRET=你的AppSecret
