# ============================================
# OpenClaw + QQ Bot 环境变量配置
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================

# ---------- LLM API 配置 ----------
# 至少配置一个 LLM 提供商的 API Key，否则机器人无法回复
# 支持 OpenAI / Anthropic / DeepSeek 等兼容接口

# 阿里云百炼 / 通义千问（推荐，国内最稳定）
# 获取方式：https://bailian.console.aliyun.com/ → API-KEY 管理
# MODELSTUDIO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# OpenAI 或兼容 API
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ---------- QQ Bot 配置 ----------
# 在 https://q.qq.com/ 创建机器人后获取
# AppID: 机器人管理页面 → 开发 → 开发设置 → AppID
# AppSecret: 同页面 → AppSecret（点击重置可重新生成）

QQBOT_APPID=你的AppID
QQBOT_SECRET=你的AppSecret

# 也可直接填写合并后的 Token（格式: AppID:AppSecret）
# 如果同时填写了 APPID 和 SECRET，脚本会自动拼接，无需填此项
# QQBOT_TOKEN=你的AppID:你的AppSecret
